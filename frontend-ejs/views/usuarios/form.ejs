<%- include("../partials/header", { title }) %>

<section class="page-heading">
  <h1><%= title %></h1>
  <p>Formulario conectado al backend JWT mediante Fetch desde el controlador.</p>
</section>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form class="form-panel" action="<%= action %>" method="<%= method %>">
  <label for="nombre">Nombre</label>
  <input id="nombre" name="nombre" type="text" value="<%= usuario.nombre || usuario.name || '' %>" required>

  <label for="correo">Correo</label>
  <input id="correo" name="correo" type="email" value="<%= usuario.correo || usuario.email || '' %>" required>

  <label for="rol">Rol</label>
  <input id="rol" name="rol" type="text" value="<%= usuario.rol || usuario.role || '' %>" placeholder="admin, usuario, instructor">

  <label for="contrasena">Contrasena</label>
  <input id="contrasena" name="contrasena" type="password" <%= usuario.id ? '' : 'required' %>>
  <% if (usuario.id) { %>
    <small>Deja este campo vacio si no deseas cambiar la contrasena.</small>
  <% } %>

  <div class="form-actions">
    <a class="secondary-button" href="/usuarios">Cancelar</a>
    <button type="submit">Guardar</button>
  </div>
</form>

<%- include("../partials/footer") %>
